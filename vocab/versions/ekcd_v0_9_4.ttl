@prefix : <http://dh.aks.ac.kr/ontologies/ekcd#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix edm: <http://www.europeana.eu/schemas/edm/> .
@prefix ekc: <http://dh.aks.ac.kr/ontologies/ekc#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix ekcd: <http://dh.aks.ac.kr/ontologies/ekcd#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <http://dh.aks.ac.kr/ontologies/ekcd#> .

<http://dh.aks.ac.kr/ontologies/ekcd> rdf:type owl:Ontology ;
                                       owl:versionIRI <http://dh.aks.ac.kr/ontologies/ekcd_v1> ;
                                       dc:creator <https://orcid.org/0009-0007-4477-6547> ,
                                                  "Dong Shin SEO"@en ,
                                                  "서동신"@ko ;
                                       dc:description "A personal derivative ontology extending the EKC line for date-oriented datatype properties, local usage guidance for semantic mapping predicates, and project-level semantic extensions in Korean cultural heritage knowledge modeling."@en ,
                                                      "한국 문화유산 지식 모델링을 위해 EKC 계열을 확장한 개인 파생 온톨로지로서, 날짜 중심 datatype property, 시맨틱 매핑 표준 속성의 로컬 사용지침, 프로젝트 수준의 의미론적 확장을 제공한다."@ko ;
                                       dc:publisher "The Center for Digital Humanities at the Academy of Korean Studies"@en ,
                                                    "한국학중앙연구원 디지털인문학연구소"@ko ;
                                       dc:title "EKCD Ontology: EKC-derived personal extension ontology"@en ,
                                                "EKCD 온톨로지: EKC 파생 개인 확장 온톨로지"@ko ;
                                       dcterms:issued "2026-03-31"^^xsd:date ;
                                       dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
                                       dcterms:modified "2026-03-31"^^xsd:date ;
                                       dcterms:replaces <http://dh.aks.ac.kr/ontologies/ekc-2022-alpha2507> ;
                                       dcterms:source <https://github.com/dongshins/EKC_ontology> ;
                                       rdfs:comment "The EKC Ontology is a domain-specific vocabulary for modeling relationships among historical facts, source documents, persons, and locations in Korean cultural heritage. Initially developed during the Encyclopedic Archives of Korean Culture digitization project at the Academy of Korean Studies and refined through various digital humanities projects."@en ,
                                                    "The present specification is based on the document \\\"Ontology:EKC 2022\\\", originally led by Hyeon Kim in the Center for Digital Humanities at the Academy of Korean Studies." ;
                                       rdfs:seeAlso "https://dh.aks.ac.kr/~hanyang2/wiki/index.php/Ontology:EKC_2022" ,
                                                    "https://github.com/dongshins/EKC_ontology" ,
                                                    "https://github.com/dongshins/EKC_ontology_advanced" ;
                                       owl:priorVersion <http://dh.aks.ac.kr/ontologies/ekc-2022-alpha2507> ;
                                       owl:versionInfo "EKCD v0.9.4"@en ;
                                       dcat:contactPoint <https://github.com/dongshins> .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/contributor
dc:contributor rdf:type owl:AnnotationProperty ;
               dc:description "기여자 정보를 텍스트성 내용(문자열) 또는 IRI로 기입함. 여타 개체를 대상으로 지정 시에는 'dcterms:contributor'(Object Property)를 사용하기로 함.(EKC 2025 방침)" ;
               rdfs:label "contributor"@en ;
               skos:note "기여자"@ko .


###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty ;
           dc:description "창작자 정보를 텍스트성 내용(문자열) 또는 IRI로 기입함. 여타 개체를 대상으로 지정 시에는 'dcterms:creator'(Object Property)를 사용하기로 함.(EKC 2025 방침)" ;
           rdfs:label "creator"@en ;
           skos:note "창작자(저자)로 인정받는 제작자"@ko ;
           skos:scopeNote "Domain : Record/Object" .


###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty ;
               dc:description "An account of the resource."@en ,
                              "해당 자원에 대한 설명"@ko ,
                              "An account of the resource.(해당 자원에 대한 설명)" ;
               rdfs:label "description" .


###  http://purl.org/dc/elements/1.1/publisher
dc:publisher rdf:type owl:AnnotationProperty ;
             dc:description "출판자 정보를 텍스트성 내용(문자열) 또는 IRI로 기입함. 여타 개체를 대상으로 지정 시에는 'dcterms:publisher'(Object Property)를 사용하기로 함.(EKC 2025 방침)" ;
             rdfs:label "publisher"@en ;
             skos:note "필사/간행/중간/영인"@ko .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty ;
         dc:description "A name given to the resource."@en ,
                        "해당 자원에 부여된 이름"@ko ,
                        "A name given to the resource.(해당 자원에 부여된 이름)" ;
         rdfs:label "title"@en .


###  http://purl.org/dc/terms/issued
dcterms:issued rdf:type owl:AnnotationProperty ;
               dc:description "Date of formal issuance of the resource."@en ,
                              "해당 자원의 공식 발행일"@ko ,
                              "Date of formal issuance of the resource.(해당 자원의 공식 발행일)" ;
               rdfs:label "Date issued"@en ;
               rdfs:range rdfs:Literal .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty ;
                dc:description "A legal document giving official permission to do something with the resource."@en ,
                               "해당 자원을 가지고 어떤 일을 할 수 있도록 공식적인 허가를 부여하는 법적 문서"@ko ,
                               "A legal document giving official permission to do something with the resource.(해당 자원을 가지고 어떤 일을 할 수 있도록 공식적인 허가를 부여하는 법적 문서)" ;
                rdfs:label "license"@en .


###  http://purl.org/dc/terms/modified
dcterms:modified rdf:type owl:AnnotationProperty ;
                 dc:description "Date on which the resource was changed."@en ,
                                "해당 자원이 변경된 날짜"@ko ,
                                "Date on which the resource was changed.(해당 자원이 변경된 날짜)" ;
                 rdfs:label "Date modified"@en ;
                 rdfs:range rdfs:Literal .


###  http://purl.org/dc/terms/replaces
dcterms:replaces rdf:type owl:AnnotationProperty ;
                 dc:description "A related resource that is supplanted, displaced, or superseded by the described resource."@en ,
                                "설명된 자원으로 대체되거나, 밀려나거나, 교체된 관련 자원"@ko ,
                                "A related resource that is supplanted, displaced, or superseded by the described resource.(설명된 자원으로 대체되거나, 밀려나거나, 교체된 관련 자원)" ;
                 rdfs:label "replaces"@en .


###  http://purl.org/dc/terms/source
dcterms:source rdf:type owl:AnnotationProperty ;
               dc:description "This property is intended to be used with non-literal values. The described resource may be derived from the related resource in whole or in part. Best practice is to identify the related resource by means of a URI or a string conforming to a formal identification system."@en ;
               rdfs:label "source"@en ;
               skos:definition "A related resource from which the described resource is derived."@en .


###  http://www.w3.org/2002/07/owl#versionIRI
owl:versionIRI rdf:type owl:AnnotationProperty ;
               dc:description "The version IRI of an ontology."@en ,
                              "온톨로지의 버전 IRI"@ko ,
                              "The version IRI of an ontology.(온톨로지의 버전 IRI)" ;
               rdfs:label "versionIRI"@en .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty ;
                dc:description "Definition"@en ,
                               "정의"@ko ,
                               "Definition(정의)" ;
                rdfs:label "definition"@en ;
                rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty ;
             dc:description "Example"@en ,
                            "예시"@ko ,
                            "Example(예시)" ;
             rdfs:label "example"@en ;
             rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#note
skos:note rdf:type owl:AnnotationProperty ;
          dc:description "Note"@en ,
                         "노트"@ko ,
                         "Note(노트)" ;
          rdfs:label "note"@en .


###  http://www.w3.org/2004/02/skos/core#scopeNote
skos:scopeNote rdf:type owl:AnnotationProperty ;
               dc:description "Scope note."@en ,
                              "범위 노트"@ko ,
                              "Scope note.(범위 노트)" ;
               rdfs:label "scopeNote"@en ;
               rdfs:subPropertyOf skos:note .


###  http://www.w3.org/ns/dcat#contactPoint
dcat:contactPoint rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://dh.aks.ac.kr/ontologies/ekc#A1
ekc:A1 rdf:type owl:ObjectProperty ;
       rdfs:label "A1"@en ;
       skos:definition "인적 관계"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#A2
ekc:A2 rdf:type owl:ObjectProperty ;
       rdfs:label "A2"@en ;
       skos:definition "문헌/작품/사건의 역할자"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#A3
ekc:A3 rdf:type owl:ObjectProperty ;
       rdfs:label "A3"@en ;
       skos:definition "인물과 기관/단체의 관계"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#A4
ekc:A4 rdf:type owl:ObjectProperty ;
       rdfs:label "A4"@en ;
       skos:definition "관직 관련 관계"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#AR
ekc:AR rdf:type owl:ObjectProperty ;
       rdfs:label "AR"@en ;
       skos:definition "건조물 관련 관계"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#CL
ekc:CL rdf:type owl:ObjectProperty ;
       rdfs:label "CL"@en ;
       skos:definition "복식 관련 관계"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#CO
ekc:CO rdf:type owl:ObjectProperty ;
       rdfs:label "CO"@en ;
       skos:definition "개념적/포괄적 관계"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#E1
ekc:E1 rdf:type owl:ObjectProperty ;
       rdfs:label "E1"@en ;
       skos:definition "이벤트 관련 관계: 사건"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#E2
ekc:E2 rdf:type owl:ObjectProperty ;
       rdfs:label "E2"@en ;
       skos:definition "이벤트 관련 관계: 행사"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#E3
ekc:E3 rdf:type owl:ObjectProperty ;
       rdfs:label "E3"@en ;
       skos:definition "이벤트 관련 관계: 공연"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#E4
ekc:E4 rdf:type owl:ObjectProperty ;
       rdfs:label "E4"@en ;
       skos:definition "이벤트 관련 관계: 전시"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#FO
ekc:FO rdf:type owl:ObjectProperty ;
       rdfs:label "FO"@en ;
       skos:definition "음식 관련 관계"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#HR
ekc:HR rdf:type owl:ObjectProperty ;
       rdfs:label "HR"@en ;
       skos:definition "문화재 관련 관계"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#NM
ekc:NM rdf:type owl:ObjectProperty ;
       rdfs:label "NM"@en ;
       skos:definition "이름 사이의 관계"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#OB
ekc:OB rdf:type owl:ObjectProperty ;
       rdfs:label "OB"@en ;
       skos:definition "물품 관련 관계"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#P1
ekc:P1 rdf:type owl:ObjectProperty ;
       rdfs:label "P1"@en ;
       skos:definition "장소를 설명하는 관계"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#P2
ekc:P2 rdf:type owl:ObjectProperty ;
       rdfs:label "P2"@en ;
       skos:definition "장소가 목적어인 관계"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#RE
ekc:RE rdf:type owl:ObjectProperty ;
       rdfs:label "RE"@en ;
       skos:definition "기록물/유물 관련 관계"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#ST
ekc:ST rdf:type owl:ObjectProperty ;
       rdfs:label "ST"@en ;
       skos:definition "스토리텔링 구성을 지시하는 관계"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#TM
ekc:TM rdf:type owl:ObjectProperty ;
       rdfs:label "TM"@en ;
       skos:definition "연표의 구성을 지시하는 관계"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#XR
ekc:XR rdf:type owl:ObjectProperty ;
       rdfs:label "XR"@en ;
       skos:definition "참고자료를 지시하는 관계"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#administrates
ekc:administrates rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf ekc:E2 ;
                  owl:inverseOf ekc:isAdministratedBy ;
                  rdfs:domain ekc:Actor ;
                  rdfs:range ekc:Event ;
                  dc:description "~를 주관하다"@ko ;
                  rdfs:label "administrates"@en ;
                  skos:example "가례도감 - 가례"@ko ;
                  skos:note "의례·제도에서의 주관행위"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#annotator
ekc:annotator rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf ekc:A2 ;
              owl:inverseOf ekc:isAnnotatorOf ;
              rdfs:domain ekc:Record ;
              rdfs:range ekc:Actor ;
              dc:description "주석가는 ~이다"@ko ;
              rdfs:label "annotator"@en ;
              skos:example "용비어천가 - 성삼문"@ko ;
              skos:note "주석자"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#appearsIn
ekc:appearsIn rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf ekc:E3 ;
              rdfs:domain ekc:Actor ;
              rdfs:range ekc:Concept ;
              dc:description "(작품, 공연) ~에 출연하다"@ko ;
              rdfs:label "appearsIn"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#archiveHolding
ekc:archiveHolding rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf ekc:XR ;
                   dc:description "아카이브 소장 목록(자료)는 ~이다 ※ 목적어는 아카이브의 소장품(소장도서) 카타로그"@ko ;
                   rdfs:label "archiveHolding"@en ;
                   skos:scopeNote "Range : Index/WebResource" .


###  http://dh.aks.ac.kr/ontologies/ekc#bibliography
ekc:bibliography rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf ekc:XR ;
                 dc:description "참고문헌 목록은 ~이다 ※ 목적어는 참고문헌 색인(bib-XXXX) 노드" ;
                 rdfs:label "bibliography"@en ;
                 skos:scopeNote "Range : Index/Bibliography" .


###  http://dh.aks.ac.kr/ontologies/ekc#calligrapher
ekc:calligrapher rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf ekc:A2 ;
                 owl:inverseOf ekc:isCalligrapherOf ;
                 rdfs:domain ekc:Record ;
                 rdfs:range ekc:Actor ;
                 dc:description "(금석문의) 글씨 쓴 이는 ~이다"@ko ;
                 skos:example "김원(신라) - 장흥 보림사 보조선사탑비"@ko ;
                 skos:note "글씨 쓴 사람. 비문/편액/제액 글씨 쓴 사람."@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#commemorates
ekc:commemorates rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf ekc:OB ;
                 rdfs:range ekc:Event ;
                 dc:description "~를 기념하다"@ko ;
                 rdfs:label "commemorates"@en ;
                 skos:note "A는 B를 기념하여 만들어졌다" ;
                 skos:scopeNote "Domain : Object/Event/Record" .


###  http://dh.aks.ac.kr/ontologies/ekc#constructor
ekc:constructor rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf ekc:AR ;
                owl:inverseOf ekc:isConstructorOf ;
                rdfs:domain ekc:Architecture ;
                rdfs:range ekc:Actor ;
                dc:description "건축가는 ~이다"@ko ;
                rdfs:label "constructor"@en ;
                skos:example "소양강댐 - 현대건설"@ko ;
                skos:note "건축을 지휘"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#cooks
ekc:cooks rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf ekc:FO ;
          rdfs:domain ekc:Actor ;
          rdfs:range ekc:Food ;
          dc:description "음식 ~을 조리한다"@ko ;
          rdfs:label "cooks"@en ;
          skos:scopeNote "Domain : Agent(Actor의 subclasses 중 기관, 단체 등)" .


###  http://dh.aks.ac.kr/ontologies/ekc#creatorPresumed
ekc:creatorPresumed rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf ekc:A2 ;
                    rdfs:range ekc:Actor ;
                    dc:description "(문헌/작품의) 작가는 ~라고 알려져 있다"@ko ;
                    rdfs:label "creatorPresumed"@en ;
                    skos:note "A의 작가는 B라고 알려져 있다" ;
                    skos:scopeNote "Domain : Record/Object" .


###  http://dh.aks.ac.kr/ontologies/ekc#curates
ekc:curates rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf ekc:E4 ;
            rdfs:domain ekc:Event ;
            dc:description "~를 전시(큐레이션)하다"@ko ;
            rdfs:label "curates"@en ;
            skos:scopeNote "Range : Object/Record/Event" .


###  http://dh.aks.ac.kr/ontologies/ekc#depicts
ekc:depicts rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf ekc:RE ;
            owl:inverseOf ekc:isDepictedIn ;
            dc:description "~를 묘사하다"@ko ;
            rdfs:label "depicts"@en ;
            skos:example "고산구곡도설 - 고산구곡도"@ko ;
            skos:note "A가 묘사하는 주된 대상이 B이다" ;
            skos:scopeNote "Domain : Object/Record" .


###  http://dh.aks.ac.kr/ontologies/ekc#documents
ekc:documents rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf ekc:RE ;
              owl:inverseOf ekc:isDocumentedIn ;
              rdfs:domain ekc:Record ;
              rdfs:range ekc:Event ;
              dc:description "~를 문서화하다"@ko ;
              rdfs:label "documents"@en ;
              skos:example "영조정순왕후가례도감의궤 - 영조-정순왕후_가례"@ko ;
              skos:note "A:기록물(예:의궤), B: 기록되는 대상(예:의례)" .


###  http://dh.aks.ac.kr/ontologies/ekc#doner
ekc:doner rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf ekc:A2 ;
          rdfs:range ekc:Actor ;
          dc:description "(유물의) 기증자는 ~이다"@ko ;
          rdfs:label "doner"@en ;
          skos:scopeNote "Domain : Record/Object" .


###  http://dh.aks.ac.kr/ontologies/ekc#editor
ekc:editor rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf ekc:A2 ;
           rdfs:domain ekc:Record ;
           rdfs:range ekc:Actor ;
           dc:description "편집자는 ~이다"@ko ;
           rdfs:label "editor"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#enshrines
ekc:enshrines rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf ekc:P1 ;
              owl:inverseOf ekc:isEnshrinedIn ;
              dc:description "~를 제향하다"@ko ;
              rdfs:label "enshrines"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#founder
ekc:founder rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf ekc:AR ;
            owl:inverseOf ekc:isFounderOf ;
            rdfs:range ekc:Actor ;
            dc:description "설립자는 ~이다"@ko ;
            rdfs:label "founder"@en ;
            skos:example "현대미술가협회 - 하인두"@ko ;
            skos:note "기관/단체/장소 설립자. 권위로써 무엇을 만들도록 함."@ko ;
            skos:scopeNote "Domain : Architecture/Agent(Actor의 subclasses 중 기관, 단체 등)" .


###  http://dh.aks.ac.kr/ontologies/ekc#goesWith
ekc:goesWith rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf ekc:OB ;
             rdfs:domain ekc:Object ;
             rdfs:range ekc:Object ;
             dc:description "~를 수반하다"@ko ;
             rdfs:label "goesWith"@en ;
             skos:example "외궤 - 내함"@ko ;
             skos:note """의식에서 물품 간의 수반 관계
A는 B와 함께 착용하였다/사용되었다
A는 B에 올려졌다
A는 B를 담는다/감싼다
A는 B로 운반되었다""" .


