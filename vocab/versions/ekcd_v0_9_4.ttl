###  http://dh.aks.ac.kr/ontologies/ekc#wasPosthumouslyPromotedTo
ekc:wasPosthumouslyPromotedTo rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf ekc:A4 ;
                              rdfs:domain ekc:Actor ;
                              rdfs:range ekc:Concept ;
                              dc:description "증직 ~를 받다"@ko ;
                              rdfs:label "wasPosthumouslyPromotedTo"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#wasPreceptorOf
ekc:wasPreceptorOf rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf ekc:A1 ;
                   rdfs:label "wasPreceptorOf"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#wears
ekc:wears rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf ekc:CL ;
          rdfs:domain ekc:Actor ;
          rdfs:range ekc:Clothing ;
          dc:description "복장 ~를 입다"@ko ;
          rdfs:label "wears"@en ;
          skos:example "궁녀 - 당의"@ko ;
          skos:note "궁중복식에서 입는 대상"@ko .


###  http://dh.aks.ac.kr/ontologies/ekc#writer
ekc:writer rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf ekc:A2 ;
           rdfs:domain ekc:Record ;
           rdfs:range ekc:Actor ;
           dc:description "(금석문의) 글 쓴 이는 ~이다"@ko ;
           rdfs:label "writer"@en ;
           skos:example "김언경 - 장흥 보림사 보조선사탑비"@ko ;
           skos:note "글 쓴 사람. 비문 지은이."@ko .


###  http://purl.org/dc/terms/contributor
dcterms:contributor rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf ekc:A2 ;
                    rdfs:range ekc:Actor ;
                    dc:description "기여자는 ~이다 ※ Range로 개체를 지정해야 함. 대상으로 텍스트성 내용(문자열) 또는 IRI를 기입 시에는 'dc:contributor'(Annotation Property)를 사용하기로 함.(EKC 2025 방침)" ;
                    rdfs:label "contributor"@en ;
                    skos:example "장흥 보림사 - 신라 헌강왕"@ko ;
                    skos:note "기여자"@ko ;
                    skos:scopeNote "Domain : Record/Object/Event" .


###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf ekc:A2 ;
                rdfs:range ekc:Actor ;
                dc:description "창작자는 ~이다 ※ Range로 개체를 지정해야 함. 대상으로 텍스트성 내용(문자열) 또는 IRI를 기입 시에는 'dc:creator'(Annotation Property)를 사용하기로 함.(EKC 2025 방침)" ;
                rdfs:label "creator"@en ;
                skos:note "창작자(저자)로 인정받는 제작자"@ko ;
                skos:scopeNote "Domain : Record/Object" .


###  http://purl.org/dc/terms/hasPart
dcterms:hasPart rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf ekc:CO ;
                owl:inverseOf dcterms:isPartOf ;
                dc:description "부분 ~이 있다"@ko ;
                rdfs:label "hasPart"@en ;
                skos:example "도산십이곡 - 도산십이곡 발문"@ko ;
                skos:note "전체-부분 관계"@ko ;
                skos:scopeNote "relation attribute : 수량(quantity. 예: 5개)" .


###  http://purl.org/dc/terms/isPartOf
dcterms:isPartOf rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf ekc:CO ;
                 dc:description "~의 부분이다"@ko ;
                 rdfs:label "isPartOf"@en ;
                 skos:example "도산십이곡 발문 - 도산십이곡"@ko ;
                 skos:note "부분-전체 관계"@ko .


###  http://purl.org/dc/terms/isReferencedBy
dcterms:isReferencedBy rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf ekc:RE ;
                       owl:inverseOf dcterms:references ;
                       rdfs:label "isReferencedBy"@en .


###  http://purl.org/dc/terms/provenance
dcterms:provenance rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf ekc:RE ;
                   dc:description "(소장품의) 기원/유래/출처는 ~이다 ※ 출처: 원 소유자, 원 소장처, 발견·발굴 장소, 기증자 등"@ko ;
                   rdfs:label "provenance"@en ;
                   skos:example "왕오천축국전 - 돈황석굴"@ko ;
                   skos:note "출처; 원 소장처; 발견·발굴 장소"@ko ;
                   skos:scopeNote "Domain : Record/Object" ,
                                  "Range : Actor/Place" .


###  http://purl.org/dc/terms/publisher
dcterms:publisher rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf ekc:A2 ;
                  rdfs:domain ekc:Record ;
                  rdfs:range ekc:Actor ;
                  dc:description "출판자는 ~이다 ※ Range로 개체를 지정해야 함. 대상으로 텍스트성 내용(문자열) 또는 IRI를 기입 시에는 'dc:publisher'(Annotation Property)를 사용하기로 함.(EKC 2025 방침)"@ko ;
                  rdfs:label "publisher"@en ;
                  skos:example "어제계주윤음 - 교서관"@ko ;
                  skos:note "필사/간행/중간/영인"@ko .


###  http://purl.org/dc/terms/references
dcterms:references rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf ekc:RE ;
                   rdfs:range ekc:Record ;
                   dc:description "~를 참고하다"@ko ;
                   rdfs:label "references"@en ;
                   skos:example "고산구곡도 - 고산구곡가"@ko ;
                   skos:note "실제 내용의 참조"@ko ;
                   skos:scopeNote "Domain : Record/Concept" .


###  http://purl.org/dc/terms/rightsHolder
dcterms:rightsHolder rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf ekc:A2 ;
                     rdfs:range ekc:Actor ;
                     dc:description "저작권자는 ~이다 ※ 저작권 보유자"@ko ;
                     rdfs:label "rightsHolder"@en ;
                     skos:example "세종대왕 표준영정 - 운보문화재단"@ko ;
                     skos:note "저작권 보유자"@ko ;
                     skos:scopeNote "Domain : Record/Object" .


###  http://purl.org/dc/terms/type
dcterms:type rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf ekc:CO ;
             dc:description "유형은 ~이다"@ko ;
             rdfs:label "type"@en ;
             skos:example "세종대왕 표준영정 - 표준영정"@ko ;
             skos:note "특정 분류체계에 배속 시. 그 외의 성격/유형은 edm:isRelatedTo." .


###  http://www.europeana.eu/schemas/edm/currentLocation
edm:currentLocation rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf ekc:P2 ;
                    rdfs:domain ekc:Object ;
                    dc:description "소재지(소장처)는 ~이다"@ko ;
                    rdfs:label "currentLocation"@en ;
                    skos:example "고성 유점사 종 - 고성 보현사"@ko ;
                    skos:note "현재 소장처"@ko ;
                    skos:scopeNote "Range : Place/Agent" .


###  http://www.europeana.eu/schemas/edm/formerLocation
edm:formerLocation rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf ekc:P2 ;
                   rdfs:domain ekc:Object ;
                   dc:description "옛 소재지(소장처)는 ~이다"@ko ;
                   rdfs:label "formerLocation"@en ;
                   skos:example "고성 유점사 종 - 고성 유점사"@ko ;
                   skos:note "과거 소장처"@ko ;
                   skos:scopeNote "Range : Place/Agent" .


###  http://www.europeana.eu/schemas/edm/happenedAt
edm:happenedAt rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf ekc:E1 ;
               rdfs:domain ekc:Event ;
               rdfs:range ekc:Place ;
               dc:description "(사건이) 장소 ~에서 일어나다"@ko ;
               rdfs:label "happenedAt"@en ;
               skos:example "명량대첩 - 명량해협"@ko ;
               skos:note "사건이 발생한 장소"@ko .


###  http://www.europeana.eu/schemas/edm/isDerivativeOf
edm:isDerivativeOf rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf ekc:RE ;
                   dc:description "~의 파생물이다"@ko ;
                   rdfs:label "isDerivativeOf"@en ;
                   skos:example "삼강행실도 언해 - 삼강행실도"@ko ;
                   skos:note "파생작; 번역물"@ko ;
                   skos:scopeNote "Domain : Record/Object" ,
                                  "Range : Record/Object" .


###  http://www.europeana.eu/schemas/edm/isNextInSequenceTo
edm:isNextInSequenceTo rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf ekc:CO ;
                       dc:description "(순서상) ~ 다음이다 ※ 사건, 항목 간의 인접연속 관계. B 다음이 A인 순서." ;
                       rdfs:label "isNextInSequenceTo"@en ;
                       skos:example "2번 - 1번" ;
                       skos:note "사건, 항목 간의 인접연속 관계. A가 B 다음인 순서." ;
                       skos:scopeNote "Domain : Event/Concept" ,
                                      "Range : Event/Concept" .


###  http://www.europeana.eu/schemas/edm/isRelatedTo
edm:isRelatedTo rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf ekc:CO ;
                dc:description "~와 관계가 있다"@ko ;
                rdfs:label "isRelatedTo"@en ;
                skos:note "기타 포괄적 연관 관계"@ko .


###  http://www.europeana.eu/schemas/edm/isShownAt
edm:isShownAt rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf ekc:XR ;
              rdfs:range ekc:WebResource ;
              dc:description "(웹 자원) ~에 보인다"@ko ;
              rdfs:label "isShownAt"@en ;
              skos:scopeNote "Domain : Any/Index" ,
                             "relation attribute : 해설, 참고, 원문 ※ subclass 명칭" .


###  http://www.europeana.eu/schemas/edm/isShownBy
edm:isShownBy rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf ekc:XR ;
              dc:description "(웹 자원) ~에 보인다"@ko ;
              rdfs:label "isShownBy"@en ;
              skos:scopeNote "Domain : Any/Index" ,
                             "Range : WebResource/Multimedia" ,
                             "relation attribute : 3D_지도, 3D_모델, 지도, 그림, 도면, 동영상, 사진 ※ subclass 명칭" .


###  http://www.europeana.eu/schemas/edm/isSuccessorOf
edm:isSuccessorOf rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf ekc:RE ;
                  dc:description "~의 후속이다 ※ 속편 작품"@ko ;
                  rdfs:label "isSuccessorOf"@en ;
                  skos:example "속장경 - 초조대장경"@ko ;
                  skos:note "속편 작품"@ko ;
                  skos:scopeNote "Domain : Record/Object" ,
                                 "Range : Record/Object" .


###  http://www.w3.org/2002/07/owl#sameAs
owl:sameAs rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf ekc:CO ;
           rdf:type owl:SymmetricProperty ,
                    owl:TransitiveProperty ;
           dc:description "두 URI가 동일한 개체(같은 resource/individual)를 가리킨다. 단순 유사성, 상호참조, 개념 대응에는 사용하지 않는다."@ko ;
           rdfs:label "sameAs"@en ;
           skos:example "<http://dh.aks.ac.kr/iri/ekc#조선_영조> - <https://www.wikidata.org/entity/Q485009>"@ko ;
           skos:note "엄격한 동일개체 관계"@ko ;
           skos:scopeNote "엄격한 동일성이 확실할 때만 사용. 개념/용어의 대응에는 skos:exactMatch 또는 skos:closeMatch를 우선 검토할 것."@ko .


###  http://www.w3.org/2004/02/skos/core#closeMatch
skos:closeMatch rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf skos:mappingRelation ;
                rdf:type owl:SymmetricProperty ;
                dc:description "~와 유사하다 ※ 다른 개념체계(어휘집)의 자원과 근접하게 대응한다. 일부 정보검색 맥락에서는 상호대체 가능하지만, 완전 동일개체를 뜻하지는 않는다."@ko ;
                rdfs:label "closeMatch"@en ;
                skos:example "개념 A(EKC) - 개념 B(외부 어휘) ※ 부분적 상호대체 가능"@ko ;
                skos:note "유사한 관계(근접 대응)"@ko ;
                skos:scopeNote "주로 Concept/Index 간의 외부 어휘 매핑에 사용. 엄격한 동일성이 아니므로 owl:sameAs 대용으로 사용하지 말 것."@ko .


###  http://www.w3.org/2004/02/skos/core#exactMatch
skos:exactMatch rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf skos:closeMatch ;
                rdf:type owl:SymmetricProperty ,
                         owl:TransitiveProperty ;
                dc:description "다른 개념체계(어휘집)의 자원과 정밀하게 대응한다. 넓은 정보검색 맥락에서 상호대체 가능하지만, OWL의 엄격한 동일성(owl:sameAs)과는 구별한다."@ko ;
                rdfs:label "exactMatch"@en ;
                skos:example "개념 A(EKC) - 개념 B(외부 어휘) ※ 광범위한 상호대체 가능"@ko ;
                skos:note "정밀 대응 관계"@ko ;
                skos:scopeNote "주로 Concept/Index 간의 외부 어휘 매핑에 사용. 완전 동일 개체가 확실할 때만 owl:sameAs를 사용."@ko .


###  http://www.w3.org/2004/02/skos/core#mappingRelation
skos:mappingRelation rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf ekc:CO ;
                     dc:description "상이한 개념체계(어휘집) 사이의 대응 관계를 묶는 상위 속성"@ko ;
                     rdfs:label "mappingRelation"@en ;
                     skos:example "개념 A(EKC) - 개념 B(외부 어휘)"@ko ;
                     skos:note "외부 개념체계 매핑의 상위 관계"@ko ;
                     skos:scopeNote "주로 Concept/Index 간의 외부 링크 정리에 사용"@ko .


###  http://xmlns.com/foaf/0.1/knows
foaf:knows rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf ekc:A1 ;
           rdfs:domain ekc:Actor ;
           rdfs:range ekc:Actor ;
           dc:description "~의 지인이다"@ko ;
           rdfs:label "knows"@en ;
           skos:example "신숙주 - 성삼문"@ko ;
           skos:note "일반적인 교유관계"@ko .


###  http://xmlns.com/foaf/0.1/member
foaf:member rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf ekc:A3 ;
            dc:description "구성원 ~이 있다"@ko ;
            rdfs:label "member"@en ;
            skos:example "집현전 - 정인지"@ko ;
            skos:note "조직-구성원 관계"@ko ;
            skos:scopeNote "Domain : Agent(Actor의 subclasses 중 기관, 단체 등)" .


#################################################################
#    Classes
#################################################################

###  http://dh.aks.ac.kr/ontologies/ekc#Actor
ekc:Actor rdf:type owl:Class ;
          dc:description "Historical figures; Organizations as collective actors and institutions as operating entities"@en ,
                         "역사적인 인물. 집단적 행위 주체로서의 단체, 운영주체로서의 기관"@ko ;
          rdfs:label "Actor"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#Architecture
ekc:Architecture rdf:type owl:Class ;
                 dc:description "Historic Buildings in a certain area and historically related structures"@en ,
                                "특정 권역의 역사적인 건조물 및 주변의 유관한 건축/조형물"@ko ;
                 rdfs:label "Architecture"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#Bibliography
ekc:Bibliography rdf:type owl:Class ;
                 dc:description "List of academic research materials"@en ,
                                "학술적 연구 자료의 목록"@ko ;
                 rdfs:label "Bibliography"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#Clothing
ekc:Clothing rdf:type owl:Class ;
             dc:description "Costumes, components of costumes, or traditional ornaments"@en ,
                            "역사적·문화적 복장과 복식 요소들"@ko ;
             rdfs:label "Clothing"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#Concept
ekc:Concept rdf:type owl:Class ;
            dc:description "Terms and concepts necessary to explain institutions, rituals, customs, etc."@en ,
                           "제도, 의례, 풍속 등을 설명하는 데 필요한 용어와 개념"@ko ;
            rdfs:label "Concept"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#Event
ekc:Event rdf:type owl:Class ;
          dc:description "Events held in a certain area, ceremonies and events that reproduce them today"@en ,
                         "특정 권역에서 일어난 사건, 의례 및 이를 재현하는 행사"@ko ;
          rdfs:label "Event"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#Food
ekc:Food rdf:type owl:Class ;
         dc:description "Food, ingredients and table setting"@en ,
                        "음식, 식재료와 상차림"@ko ;
         rdfs:label "Food"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#Heritage
ekc:Heritage rdf:type owl:Class ;
             dc:description "Registration information of designated and registered cultural properties"@en ,
                            "지정문화유산 및 등록문화유산 등록 정보"@ko ;
             rdfs:label "Heritage"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#Index
ekc:Index rdf:type owl:Class ;
          dc:description "A list of nodes of similar character. Timeline, collection list, reference list, web resource list, etc."@en ,
                         "유사한 성격의 노드들을 모아서 묶은 목록. 연표, 소장도서목록, 참고문헌목록, 웹자원목록 등"@ko ;
          rdfs:label "Index"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#Multimedia
ekc:Multimedia rdf:type owl:Class ;
               dc:description "3D model of a building; 3D map indicating the location of a specific place; visual materials"@en ,
                              "3D 모델, 특정 공간의 위치를 알리는 3차원 지도, 시각자료"@ko ;
               rdfs:label "Multimedia"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#Object
ekc:Object rdf:type owl:Class ;
           dc:description "Items used in various ceremonies or events; Items or tools that show the culture of the time"@en ,
                          "각종 의례/행사의 도구, 그 시대의 문화를 보이는 물품들"@ko ;
           rdfs:label "Object"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#Place
ekc:Place rdf:type owl:Class ;
          dc:description "Places related to historical events or characters; Places where historical relics or artifacts are located"@en ,
                         "역사적 배경(사건, 인물)과 관련이 있는 장소. 유물의 소장처"@ko ;
          rdfs:label "Place"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#Record
ekc:Record rdf:type owl:Class ;
           dc:description "Records that serve as the source of knowledge such as books, photographs, drawings, and inscriptions"@en ,
                          "문헌, 사진, 도면, 금석문 등 지식 데이터의 원천 자료가 되는 기록물"@ko ;
           rdfs:label "Record"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#Story
ekc:Story rdf:type owl:Class ;
          dc:description "Description of historical knowledge that explains the background of discovering data nodes"@en ,
                         "데이터 노드 발굴의 배경이 된 역사적 지식에 대한 서술"@ko ;
          rdfs:label "Story"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#Text
ekc:Text rdf:type owl:Class ;
         dc:description "Text in the literature that functions as evidence of explanation"@en ,
                        "설명의 증거 기능을 하는 문헌상의 텍스트"@ko ;
         rdfs:label "Text"@en .


###  http://dh.aks.ac.kr/ontologies/ekc#WebResource
