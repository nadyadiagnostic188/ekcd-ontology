@base <http://dh.aks.ac.kr/ontologies/ekcd#> .

<http://dh.aks.ac.kr/ontologies/ekcd> rdf:type owl:Ontology ;
                                       owl:versionIRI <http://dh.aks.ac.kr/ontologies/ekcd_v1> ;
                                       owl:imports <http://dh.aks.ac.kr/ontologies/ekc-2025> ;
                                       dc:creator <https://orcid.org/0009-0007-4477-6547> ,
                                                  "Dong Shin SEO"@en ,
                                                  "서동신"@ko ;
                                       dc:description "A personal derivative ontology extending the EKC line for date-oriented datatype properties, local usage guidance for semantic mapping predicates, and project-level semantic extensions in Korean cultural heritage knowledge modeling."@en ,
                                                      "한국 문화유산 지식 모델링을 위해 EKC 계열을 확장한 개인 파생 온톨로지로서, 날짜 중심 datatype property, 시맨틱 매핑 표준 속성의 로컬 사용지침, 프로젝트 수준의 의미론적 확장을 제공한다."@ko ;
                                       dc:publisher "The Center for Digital Humanities at the Academy of Korean Studies"@en ,
                                                    "한국학중앙연구원 디지털인문학연구소"@ko ;
                                       dc:title "EKCD Ontology: EKC-derived personal extension ontology"@en ,
                                                "EKCD 온톨로지: EKC 파생 개인 확장 온톨로지"@ko ;
                                       dcterms:issued "2026-04-13"^^xsd:date ;
                                       dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
                                       dcterms:modified "2026-04-13"^^xsd:date ;
                                       dcterms:replaces <http://dh.aks.ac.kr/ontologies/ekc-2022-alpha2507> ;
                                       dcterms:source <https://github.com/dongshins/EKC_ontology> ;
                                       rdfs:comment "The EKC Ontology is a domain-specific vocabulary for modeling relationships among historical facts, source documents, persons, and locations in Korean cultural heritage. Initially developed during the Encyclopedic Archives of Korean Culture digitization project at the Academy of Korean Studies and refined through various digital humanities projects."@en ;
                                       rdfs:seeAlso <https://github.com/dongshins/ekcd-ontology> ,
                                                    "https://dh.aks.ac.kr/~hanyang2/wiki/index.php/Ontology:EKC_2022" ,
                                                    "https://github.com/dongshins/EKC_ontology" ,
                                                    "https://github.com/dongshins/EKC_ontology_advanced" ;
                                       owl:priorVersion <http://dh.aks.ac.kr/ontologies/ekc-2022-alpha2507> ;
                                       owl:versionInfo "EKCD v0.9.29"@en ;
                                       dcat:contactPoint <https://github.com/dongshins> .

